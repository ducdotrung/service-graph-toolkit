# GitNexus per-repo indexes (large, regenerable)
.gitnexus/
**/.gitnexus/
indexes/

# Generated from inventory.yaml or local GitNexus runs
group.yaml
views/inventory.json
views/inventory.schema.json
views/service-map.md
views/services/
views/drift-report.md
views/filtered-bridge.json

# Editor / OS scratch
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Local-only scratch notes (use docs/ for shared)
SCRATCH.md
NOTES.local.md
*.local.md

# Build / cache
__pycache__/
*.pyc
node_modules/

# Node / frontend build output
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/

# Unit test reports
TEST*.xml

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv
